# Application
MAPDIR=..
APP_ENV=local
APP_USER=www
APP_DEBUG=true
UID=1000
GID=1000

# DB
MYSQL_ROOT_PASSWORD=secret
DB_PORT=3306
DB_CONNECTION=mysql
DB_HOST=mariadb
REDIS_PASSWORD=redis

# Hosting
WORKDIR=/var/www
TYPESENSE_API_KEY=xyz

# Software
NODE_VERSION=24.16.0

# Debugging
XDEBUG_MODE=debug
XDEBUG_IDEKEY=XDEBUG
XDEBUG_TRIGGER=XDEBUG
XDEBUG_HOST=host.docker.internal
LIVERELOAD=false
